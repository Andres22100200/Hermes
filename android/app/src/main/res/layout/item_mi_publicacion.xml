<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Foto del libro -->
        <ImageView
            android:id="@+id/imgLibro"
            android:layout_width="80dp"
            android:layout_height="110dp"
            android:scaleType="centerCrop"
            android:background="@android:color/darker_gray"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="Foto del libro"/>

        <!-- Título -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Título del libro"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgLibro"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"/>

        <!-- Precio -->
        <TextView
            android:id="@+id/tvPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$150"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/dark_blue"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo"
            app:layout_constraintStart_toEndOf="@id/imgLibro"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"/>

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponible"
            android:textSize="12sp"
            android:textColor="@android:color/holo_green_dark"
            app:layout_constraintTop_toBottomOf="@id/tvPrecio"
            app:layout_constraintStart_toEndOf="@id/imgLibro"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"/>

        <!-- Botón Editar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:text="Editar"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:layout_constraintTop_toBottomOf="@id/tvEstado"
            app:layout_constraintStart_toEndOf="@id/imgLibro"
            app:layout_constraintEnd_toStartOf="@id/btnEliminar"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"/>

        <!-- Botón Eliminar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:text="Eliminar"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="@android:color/holo_red_dark"
            app:layout_constraintTop_toBottomOf="@id/tvEstado"
            app:layout_constraintStart_toEndOf="@id/btnEditar"
            app:layout_constraintEnd_toStartOf="@id/btnDesactivar"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"/>

        <!-- Botón Desactivar/Activar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDesactivar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:text="Desactivar"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="@android:color/holo_orange_dark"
            app:layout_constraintTop_toBottomOf="@id/tvEstado"
            app:layout_constraintStart_toEndOf="@id/btnEliminar"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>