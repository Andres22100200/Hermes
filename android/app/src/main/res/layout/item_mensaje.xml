<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <!-- Mensaje del otro usuario (izquierda) -->
    <LinearLayout
        android:id="@+id/layoutMensajeOtro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="64dp"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:elevation="2dp"
            android:backgroundTint="#FFFFFF">

            <TextView
                android:id="@+id/tvMensajeOtro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:padding="12dp"
                android:text="Mensaje del otro usuario"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvHoraOtro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:text="12:30"
            android:textColor="@android:color/darker_gray"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Mensaje propio (derecha) -->
    <LinearLayout
        android:id="@+id/layoutMensajePropio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="64dp"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:elevation="2dp"
            android:backgroundTint="@color/dark_blue">

            <TextView
                android:id="@+id/tvMensajePropio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:padding="12dp"
                android:text="Mi mensaje"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvHoraPropio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:text="12:31"
            android:textColor="@android:color/darker_gray"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Mensaje de sistema (centro) -->
    <TextView
        android:id="@+id/tvMensajeSistema"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="4dp"
        android:background="#E0E0E0"
        android:padding="8dp"
        android:text="Mensaje del sistema"
        android:textColor="@android:color/darker_gray"
        android:textSize="12sp"
        android:visibility="gone" />

</FrameLayout>